# ====================================
# DINAND NEWS - Environment Variables
# ====================================
# Copy this file to .env.local and fill in real values

# ---- Site Configuration ----
# For local dev, use http://localhost:3000
# For production, use https://news.autoflowa.in
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Dinand News

# ---- Supabase ----
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---- Groq AI (FREE) ----
# Get free key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# ---- Ingest API Secret ----
# Generate with: openssl rand -hex 32
# Used by n8n / Vercel Cron to authenticate to /api/ingest
INGEST_API_SECRET=your_super_secret_random_string_here

# ---- Cron Secret (optional, for Vercel Cron) ----
# If using Vercel Cron, this can be the same as INGEST_API_SECRET
# Or generate a separate one for added security
CRON_SECRET=your_cron_secret_here

# ---- Admin Panel ----
ADMIN_EMAIL=admin@autoflowa.in

# ---- AdSense (add later after approval) ----
# Get from https://www.google.com/adsense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
